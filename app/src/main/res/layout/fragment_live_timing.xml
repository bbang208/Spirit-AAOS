<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>
        <variable
            name="viewModel"
            type="io.github.bbang208.spirit.ui.livetiming.LiveTimingViewModel" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/background_primary">

        <!-- Top strip: Lap number + session elapsed -->
        <TextView
            android:id="@+id/tv_lap_number"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/pleos_spacing_xl"
            android:layout_marginTop="@dimen/pleos_spacing_lg"
            android:text="@{viewModel.formattedLapLabel}"
            android:textAppearance="@style/TextAppearance.Pleos.Title.Medium"
            android:textColor="@color/text_dark_primary"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tv_session_elapsed"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="@dimen/pleos_spacing_xl"
            android:text="@{viewModel.formattedSessionTime}"
            android:textAppearance="@style/TextAppearance.Pleos.Body.Large"
            android:textColor="@color/text_dark_tertiary"
            app:layout_constraintBaseline_toBaselineOf="@id/tv_lap_number"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Ghost delta bar placeholder -->
        <View
            android:id="@+id/delta_bar_placeholder"
            android:layout_width="0dp"
            android:layout_height="8dp"
            android:layout_marginStart="@dimen/pleos_spacing_xl"
            android:layout_marginTop="@dimen/pleos_spacing_md"
            android:layout_marginEnd="@dimen/pleos_spacing_xl"
            android:background="@color/surface_high"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_lap_number" />

        <!-- Center left: Current lap time (big) -->
        <TextView
            android:id="@+id/tv_lap_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/pleos_spacing_xl"
            android:text="@{viewModel.formattedLapTime}"
            android:textAppearance="@style/TextAppearance.Pleos.Feature.Speed"
            android:textColor="@color/text_dark_primary"
            app:layout_constraintBottom_toTopOf="@id/tv_sector_bar_area"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/delta_bar_placeholder" />

        <!-- Delta time -->
        <TextView
            android:id="@+id/tv_delta_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/pleos_spacing_lg"
            android:text="@{viewModel.formattedDelta}"
            android:textAppearance="@style/TextAppearance.Pleos.Headline.Small"
            android:textColor="@color/text_dark_tertiary"
            app:layout_constraintBottom_toBottomOf="@id/tv_lap_time"
            app:layout_constraintStart_toEndOf="@id/tv_lap_time" />

        <!-- Center right: Speed -->
        <TextView
            android:id="@+id/tv_speed"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="@dimen/pleos_spacing_xl"
            android:text="@{viewModel.formattedSpeed}"
            android:textAppearance="@style/TextAppearance.Pleos.Headline.Medium"
            android:textColor="@color/text_dark_primary"
            app:layout_constraintBottom_toTopOf="@id/tv_speed_unit"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/delta_bar_placeholder" />

        <TextView
            android:id="@+id/tv_speed_unit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="@dimen/pleos_spacing_xl"
            android:text="@string/unit_kmh"
            android:textAppearance="@style/TextAppearance.Pleos.Body.Medium"
            android:textColor="@color/text_dark_quaternary"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_speed" />

        <!-- Bottom strip: Sector indicators + G-Force placeholder -->
        <FrameLayout
            android:id="@+id/tv_sector_bar_area"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:layout_marginStart="@dimen/pleos_spacing_xl"
            android:layout_marginBottom="@dimen/pleos_spacing_lg"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/g_force_placeholder"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- G-Force indicator placeholder -->
        <FrameLayout
            android:id="@+id/g_force_placeholder"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_marginEnd="@dimen/pleos_spacing_xl"
            android:layout_marginBottom="@dimen/pleos_spacing_lg"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btn_stop" />

        <!-- STOP button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_stop"
            style="@style/Widget.Pleos.IconButton.Circle"
            android:layout_width="@dimen/pleos_icon_btn_lg"
            android:layout_height="@dimen/pleos_icon_btn_lg"
            android:layout_marginEnd="@dimen/pleos_spacing_xl"
            android:layout_marginBottom="@dimen/pleos_spacing_lg"
            android:backgroundTint="@color/call_end_normal"
            android:contentDescription="@string/stop_session"
            android:text="@string/stop"
            android:textColor="@color/text_dark_primary"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>
