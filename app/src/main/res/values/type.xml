<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- ===== Pleos Design System Typography ===== -->
    <!-- System Font (sans-serif), sizes in sp, line heights in sp -->
    <!-- Weight mapping: Normal=400, Strong=600, Extra_strong=700, Extrastrong=800, Bold=700 -->

    <!-- ===== Headline ===== -->
    <style name="TextAppearance.Pleos.Headline.Large" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="android:textSize">60sp</item>
        <item name="android:lineHeight">80sp</item>
        <item name="android:textFontWeight">800</item>
        <item name="android:textColor">@color/text_dark_primary</item>
    </style>

    <style name="TextAppearance.Pleos.Headline.Medium" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textSize">56sp</item>
        <item name="android:lineHeight">72sp</item>
        <item name="android:textFontWeight">800</item>
        <item name="android:textColor">@color/text_dark_primary</item>
    </style>

    <style name="TextAppearance.Pleos.Headline.Small" parent="TextAppearance.Material3.HeadlineSmall">
        <item name="android:textSize">48sp</item>
        <item name="android:lineHeight">64sp</item>
        <item name="android:textFontWeight">800</item>
        <item name="android:textColor">@color/text_dark_primary</item>
    </style>

    <!-- ===== Title ===== -->
    <style name="TextAppearance.Pleos.Title.Large" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textSize">40sp</item>
        <item name="android:lineHeight">52sp</item>
        <item name="android:textFontWeight">700</item>
        <item name="android:textColor">@color/text_dark_primary</item>
    </style>

    <style name="TextAppearance.Pleos.Title.Medium" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textSize">36sp</item>
        <item name="android:lineHeight">44sp</item>
        <item name="android:textFontWeight">700</item>
        <item name="android:textColor">@color/text_dark_primary</item>
    </style>

    <style name="TextAppearance.Pleos.Title.Small" parent="TextAppearance.Material3.TitleSmall">
        <item name="android:textSize">32sp</item>
        <item name="android:lineHeight">40sp</item>
        <item name="android:textFontWeight">700</item>
        <item name="android:textColor">@color/text_dark_primary</item>
    </style>

    <!-- ===== Body ===== -->
    <!-- Body has two weight variants: Strong (600) and Normal (400) -->
    <style name="TextAppearance.Pleos.Body.Large" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textSize">30sp</item>
        <item name="android:lineHeight">38sp</item>
        <item name="android:textFontWeight">400</item>
        <item name="android:textColor">@color/text_dark_primary</item>
    </style>

    <style name="TextAppearance.Pleos.Body.Large.Strong">
        <item name="android:textFontWeight">600</item>
    </style>

    <style name="TextAppearance.Pleos.Body.Medium" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textSize">28sp</item>
        <item name="android:lineHeight">36sp</item>
        <item name="android:textFontWeight">400</item>
        <item name="android:textColor">@color/text_dark_primary</item>
    </style>

    <style name="TextAppearance.Pleos.Body.Medium.Strong">
        <item name="android:textFontWeight">600</item>
    </style>

    <style name="TextAppearance.Pleos.Body.Small" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textSize">26sp</item>
        <item name="android:lineHeight">34sp</item>
        <item name="android:textFontWeight">400</item>
        <item name="android:textColor">@color/text_dark_primary</item>
    </style>

    <style name="TextAppearance.Pleos.Body.Small.Strong">
        <item name="android:textFontWeight">600</item>
    </style>

    <!-- ===== Label ===== -->
    <style name="TextAppearance.Pleos.Label.Medium" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:textSize">24sp</item>
        <item name="android:lineHeight">28sp</item>
        <item name="android:textFontWeight">400</item>
        <item name="android:textColor">@color/text_dark_secondary</item>
    </style>

    <style name="TextAppearance.Pleos.Label.Small" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:textSize">20sp</item>
        <item name="android:lineHeight">24sp</item>
        <item name="android:textFontWeight">400</item>
        <item name="android:textColor">@color/text_dark_secondary</item>
    </style>

    <!-- ===== Feature Font ===== -->
    <!-- Speed: large speedometer display -->
    <style name="TextAppearance.Pleos.Feature.Speed" parent="TextAppearance.Material3.DisplayLarge">
        <item name="android:textSize">112sp</item>
        <item name="android:lineHeight">134sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_dark_primary</item>
    </style>

    <!-- Traffic sign -->
    <style name="TextAppearance.Pleos.Feature.TrafficSign" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textSize">36sp</item>
        <item name="android:lineHeight">44sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_dark_primary</item>
    </style>

    <!-- Bubble -->
    <style name="TextAppearance.Pleos.Feature.Bubble" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textSize">30sp</item>
        <item name="android:lineHeight">48sp</item>
        <item name="android:textFontWeight">700</item>
        <item name="android:textColor">@color/text_dark_primary</item>
    </style>

    <!-- List number -->
    <style name="TextAppearance.Pleos.Feature.ListNumber" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textSize">28sp</item>
        <item name="android:lineHeight">36sp</item>
        <item name="android:textFontWeight">600</item>
        <item name="android:textColor">@color/text_dark_primary</item>
    </style>

</resources>
